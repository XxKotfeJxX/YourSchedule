        badge_text = "Навчання" if mark.kind == MarkKind.TEACHING else "Перерва"
        badge = tk.Label(
            top_row,
            text=badge_text,
            bg=badge_color,
            fg=self.theme.TEXT_LIGHT,
            font=("Segoe UI", 8, "bold"),
